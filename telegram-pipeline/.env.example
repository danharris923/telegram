# ============================================================
# Telegram Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# DO NOT commit .env to version control.
# ============================================================

# Telegram bot token from BotFather (/newbot command)
# Example: 1234567890:AAHxyz...
TELEGRAM_BOT_TOKEN=

# Telegram channel ID — use @channelname for public channels
# or -100xxxxxxxxxx for private channels
TELEGRAM_CHANNEL_ID=

# Path to Google Cloud service account JSON credentials file
# Example: /home/user/creds/service-account.json
GOOGLE_CREDENTIALS_JSON_PATH=

# Google Sheet ID — the long string in the sheet URL between /d/ and /edit
# Example: 1a2b3c4d5e6f7g8h9i0j
GOOGLE_SHEET_ID=

# Name of the tab/sheet within the spreadsheet
# Example: Sheet1
GOOGLE_SHEET_NAME=

# Column letter containing the links/content to post
# Example: A
GOOGLE_SHEET_LINK_COLUMN=
